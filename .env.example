# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<from pnpm db:start>
SUPABASE_SERVICE_ROLE_KEY=<from pnpm db:start>

# Database (local: direct, staging/prod: Supabase Pooler with pgbouncer)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Cron / Internal API (generate with: openssl rand -hex 32)
CRON_SECRET=<random-secret>
INTERNAL_API_KEY=<random-secret>

# AI Assistant (Anthropic)
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# App
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_APP_NAME=Terp

# Platform admin auth (separate domain from the tenant app)
# Required — generate with: openssl rand -base64 48
PLATFORM_JWT_SECRET=<random-32-byte-base64>
# Optional. Leave empty in dev to serve the platform at /platform/* on the same
# host as the tenant app. In prod, set to the subdomain (e.g. "admin.terp.de")
# to activate host-based routing and domain-scoped cookies.
PLATFORM_COOKIE_DOMAIN=
