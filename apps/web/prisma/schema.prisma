  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accounts Account[]

  // Indexes
  @@unique([tenantId, code], map: "account_groups_tenant_id_code_key")
  @@index([tenantId], map: "idx_account_groups_tenant")
