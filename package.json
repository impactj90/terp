{
  "name": "@terp/web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck && pnpm run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:browser": "playwright test",
    "test:browser:headed": "playwright test --headed",
    "test:browser:ui": "playwright test --ui",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf .next out node_modules/.cache",
    "docker:dev": "npx supabase start && docker compose -p terp -f ./docker/docker-compose.yml up --build -d",
    "docker:down": "docker compose -p terp -f ./docker/docker-compose.yml down -v --remove-orphans",
    "docker:clean": "docker compose -p terp -f ./docker/docker-compose.yml down -v --remove-orphans 2>/dev/null; docker rm -f terp-web terp-lb 2>/dev/null; npx supabase stop 2>/dev/null; true",
    "docker:logs": "docker compose -p terp -f ./docker/docker-compose.yml logs -f",
    "docker:ps": "docker compose -p terp -f ./docker/docker-compose.yml ps",
    "docker:build": "docker build -f ./docker/web.Dockerfile -t terp-web:latest .",
    "demo:dev": "npx supabase start && docker compose -p terp --env-file .env -f ./docker/docker-compose.yml -f ./docker/docker-compose.demo.yml up --build -d",
    "demo:down": "docker compose -p terp --env-file .env -f ./docker/docker-compose.yml -f ./docker/docker-compose.demo.yml down -v --remove-orphans; docker rm -f terp-web terp-caddy terp-ngrok 2>/dev/null; true",
    "demo:logs": "docker compose -p terp --env-file .env -f ./docker/docker-compose.yml -f ./docker/docker-compose.demo.yml logs -f",
    "db:start": "npx supabase start",
    "db:stop": "npx supabase stop",
    "db:reset": "npx supabase db reset",
    "db:status": "npx supabase status",
    "db:migrate:new": "npx supabase migration new",
    "db:generate": "prisma generate",
    "db:pull": "prisma db pull",
    "db:push:staging": "npx supabase db push --linked",
    "db:push:prod": "npx supabase db push --db-url \"$SUPABASE_DB_URL\"",
    "db:studio": "prisma studio",
    "seed:staging": "node --env-file=.env.staging ./scripts/seed-staging.ts",
    "db:reset:staging": "node --env-file=.env.staging ./scripts/reset-staging.ts",
    "postinstall": "prisma generate",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-devtools": "^5.91.2",
    "@trpc/client": "^11.11.0",
    "@trpc/server": "^11.11.0",
    "@trpc/tanstack-react-query": "^11.11.0",
    "class-variance-authority": "^0.7.1",
    "client-only": "^0.0.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.563.0",
    "next": "^16.1.0",
    "next-intl": "^4.7.0",
    "openapi-fetch": "^0.17.0",
    "pg": "^8.19.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.0",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@next/eslint-plugin-next": "^16.1.4",
    "@playwright/test": "1.58.2",
    "@storybook/addon-a11y": "^10.2.0",
    "@storybook/addon-docs": "^10.2.0",
    "@storybook/addon-onboarding": "^10.2.0",
    "@storybook/addon-vitest": "^10.2.0",
    "@storybook/nextjs-vite": "^10.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "eslint-plugin-storybook": "^10.2.0",
    "postcss": "^8.5.0",
    "prettier": "^3.4.0",
    "prisma": "^7.4.2",
    "storybook": "^10.2.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.53.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
