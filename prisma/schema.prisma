  periodTo        DateTime @map("period_to") @db.Timestamptz(6)
  openingBalance  Float    @map("opening_balance")
  closingBalance  Float    @map("closing_balance")
  currency        String   @db.Char(3)
  importedAt      DateTime @default(now()) @map("imported_at") @db.Timestamptz(6)
  importedById    String?  @map("imported_by_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions BankTransaction[]

  @@unique([tenantId, sha256Hash], map: "uq_bank_statements_tenant_hash")
  @@index([tenantId, importedAt(sort: Desc)], map: "idx_bank_statements_tenant_imported_at")
  @@map("bank_statements")
}

model BankTransaction {
  id                  String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String                   @map("tenant_id") @db.Uuid
