  counterpartyName    String?                  @map("counterparty_name")
  counterpartyBic     String?                  @map("counterparty_bic") @db.VarChar(11)
  remittanceInfo      String?                  @map("remittance_info")
  endToEndId          String?                  @map("end_to_end_id") @db.VarChar(255)
  mandateId           String?                  @map("mandate_id") @db.VarChar(255)
  bankReference       String?                  @map("bank_reference") @db.VarChar(255)
